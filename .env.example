# ──────────────────────────────────────────────────────────────
# FORMA — Environment Variables
# Copy this file to .env and fill in values as needed.
# All variables are OPTIONAL — FORMA runs fully client-side
# with no required backend or API keys.
# ──────────────────────────────────────────────────────────────

# Analytics (optional) — e.g. Plausible, Fathom, or a custom endpoint
# If set, basic usage events (preset loaded, note played) are reported.
# FORMA_ANALYTICS_URL=https://analytics.example.com/api/event
# FORMA_ANALYTICS_SITE_ID=forma-instrument

# Remote preset storage (optional) — REST endpoint for saving/loading
# user presets. If unset, presets are stored in localStorage only.
# FORMA_PRESET_API_URL=https://api.example.com/presets

# App version — injected at build time if using a bundler
# FORMA_VERSION=1.0.0

# Public base URL — needed only if deploying to a subdirectory
# FORMA_BASE_URL=/forma
